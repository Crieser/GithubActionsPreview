<Window x:Class="BlackJack.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BLACKJACK.exe"
        Height="550"
        Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid>

        <Image Source="/Fotos/start.png"
               Width="260"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Margin="550,-83,0,0">

            <Image.RenderTransform>
                <RotateTransform Angle="30"/>
            </Image.RenderTransform>

        </Image>

        <Border Width="320"
                Height="440"
                Background="black"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <Image Source="/Fotos/play.jpg"
                       Height="130"
                       Width="300"
                       Stretch="Uniform"
                       Margin="0,0,0,15"/>

                <TextBlock Text="BLACKJACK.exe"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <TextBlock Text="Nickname"
                           Foreground="White"
                           FontSize="14"/>

                <TextBox x:Name="UsernameBox"
         Height="35"
         Margin="0,5,0,15"
         FontSize="16"
         Background="White"
         BorderBrush="black"
         BorderThickness="1"/>

                <TextBlock Text="Passwort"
           Foreground="White"
           FontSize="14"/>

                <PasswordBox x:Name="PasswordBox"
             Height="35"
             Margin="0,5,0,25"
             FontSize="16"
             Background="White"
             BorderBrush="Black"
             BorderThickness="1"/>

                <Button Content="Login"
                        Height="40"
                        FontSize="16"
                        FontWeight="Bold"
                        Background="#4CAF50"
                        Foreground="White"
                        Click="LoginButton_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>